Options -Indexes
RewriteEngine On

# Remove .php extension from URLs (optional)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^([^\.]+)$ $1.php [NC,L]

# Protect sensitive files
<FilesMatch "\.(sql|env|log|gitignore|yaml)$">
    Require all denied
</FilesMatch>
